{
  "name": "weixin-clawbot",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/undirectlookable/weixin-clawbot.git",
    "directory": "packages/weixin-clawbot"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "weixin-clawbot": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "run:cli": "pnpm run build && node ./dist/cli.js",
    "test": "pnpm run build && node --test test/*.test.mjs",
    "test:coverage": "pnpm run build && node --test --experimental-test-coverage test/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
